{
  "name": "pglens-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for pglens — a VS Code extension for visualizing PostgreSQL schemas as ER diagrams",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter pglens watch",
    "build": "pnpm --filter pglens build",
    "build:landing": "pnpm --filter landing build",
    "typecheck": "pnpm --filter pglens lint",
    "lint": "pnpm --filter pglens lint",
    "format": "prettier --write ."
  }
}
