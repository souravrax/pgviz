---
const features = [
  {
    name: 'Interactive ER Diagrams',
    description:
      'Click any table node to inspect columns, primary keys, indexes, and foreign key relationships in a floating tabbed card.',
  },
  {
    name: 'Two-Way Selection',
    description:
      'Click a table in the graph to reveal it in the sidebar Tables panel, or click the eye icon in the panel to highlight it in the graph.',
  },
  {
    name: 'Schema Browser',
    description:
      'Browse all schemas for your active connection. Select any schema to generate its full ER diagram with automatic Dagre layout.',
  },
  {
    name: 'Secure Connections',
    description:
      'PostgreSQL URLs are stored in your OS keychain via VS Code SecretStorage. No credentials saved to disk.',
  },
  {
    name: 'Theme Aware',
    description:
      'The graph, sidebar panels, and detail cards automatically adapt to your VS Code color theme using standard CSS variables.',
  },
  {
    name: 'Rich Column Details',
    description:
      'See PK, FK, Identity, Unique, and Indexed icons alongside data types, nullability, and DEFAULT values at a glance.',
  },
];
---

<section class="py-16 sm:py-20 border-t border-stone-100 dark:border-stone-800">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col gap-12">
      <h2 class="text-2xl font-semibold tracking-tight">What it does</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((feature) => (
            <div class="flex flex-col gap-3">
              <h3 class="text-base font-medium">{feature.name}</h3>
              <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
