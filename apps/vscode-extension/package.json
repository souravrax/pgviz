{
  "name": "pglens",
  "displayName": "PgLens - PostgreSQL Schema Visualizer",
  "description": "Visualize your PostgreSQL database schemas as interactive ER diagrams",
  "version": "0.1.2",
  "publisher": "souravrax",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/souravrax/pglens"
  },
  "homepage": "https://github.com/souravrax/pglens#readme",
  "bugs": {
    "url": "https://github.com/souravrax/pglens/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Programming Languages"
  ],
  "keywords": [
    "postgresql",
    "postgres",
    "database",
    "schema",
    "er diagram",
    "visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pglens.addConnection",
        "title": "Add Connection",
        "category": "pglens",
        "icon": "$(add)"
      },
      {
        "command": "pglens.removeConnection",
        "title": "Remove Connection",
        "category": "pglens",
        "icon": "$(trash)"
      },
      {
        "command": "pglens.selectConnection",
        "title": "Select Connection",
        "category": "pglens",
        "icon": "$(plug)"
      },
      {
        "command": "pglens.deselectConnection",
        "title": "Deselect Connection",
        "category": "pglens",
        "icon": "$(close)"
      },
      {
        "command": "pglens.refreshConnections",
        "title": "Refresh Connections",
        "category": "pglens",
        "icon": "$(refresh)"
      },
      {
        "command": "pglens.refreshSchemas",
        "title": "Refresh Schemas",
        "category": "pglens",
        "icon": "$(refresh)"
      },
      {
        "command": "pglens.visualizeSchema",
        "title": "Visualize Schema",
        "category": "pglens",
        "icon": "$(graph)"
      },
      {
        "command": "pglens.visualizeSchemaFromTree",
        "title": "Visualize Schema",
        "category": "pglens",
        "icon": "$(graph)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pglens-sidebar",
          "title": "pglens",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "pglens-sidebar": [
        {
          "id": "pglens.connections",
          "name": "Connection",
          "when": "pglens:enabled"
        },
        {
          "id": "pglens.schemas",
          "name": "Schemas",
          "when": "pglens:enabled"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pglens.connections",
        "contents": "No connections configured.\n[Add Connection](command:pglens.addConnection)\n",
        "when": "pglens:noConnections"
      },
      {
        "view": "pglens.schemas",
        "contents": "No connection selected.\n[Select Connection](command:pglens.selectConnection)\n",
        "when": "pglens:noActiveConnection"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pglens.addConnection",
          "when": "view == pglens.connections",
          "group": "navigation@1"
        },
        {
          "command": "pglens.refreshConnections",
          "when": "view == pglens.connections",
          "group": "navigation@2"
        },
        {
          "command": "pglens.refreshSchemas",
          "when": "view == pglens.schemas",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "pglens.selectConnection",
          "when": "view == pglens.connections && viewItem == connection",
          "group": "inline@1"
        },
        {
          "command": "pglens.deselectConnection",
          "when": "view == pglens.connections && viewItem == connection-active",
          "group": "inline@1"
        },
        {
          "command": "pglens.removeConnection",
          "when": "view == pglens.connections && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "pglens.removeConnection",
          "when": "view == pglens.connections && viewItem == connection-active",
          "group": "inline@2"
        },
        {
          "command": "pglens.visualizeSchemaFromTree",
          "when": "view == pglens.schemas && viewItem == schema",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "pglens",
      "properties": {
        "pglens.showInternalSchemas": {
          "type": "boolean",
          "default": false,
          "description": "Show internal PostgreSQL schemas (pg_catalog, information_schema, etc.)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --target=node20",
    "compile:watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --target=node20 --watch",
    "build:webview": "cd ../webview && pnpm run build",
    "build": "npm run compile && npm run build:webview",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --target=node20 --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.7.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "pg": "^8.14.0"
  }
}
