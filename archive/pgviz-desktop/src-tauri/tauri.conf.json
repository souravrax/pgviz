{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pgviz",
  "version": "0.1.0",
  "identifier": "com.pgviz.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "pgviz",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDNzQ0NkU1OTNCMjZBRjQKUldUMGFyS1Q1VVowL0FVLzFnbDVoR1BFM3VjZzhlZFl5S2RGaGJFR2tZQ2ZqcEVteGdJbHgrbUYK",
      "endpoints": [
        "https://github.com/souravrax/pgviz/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
